PORT=3000

# Data persistence
DATA_DIR=./data
BROWSER_PROFILE_DIR=./browser-profile

# ChatGPT web URL. Keep this on the public web UI, not an internal API.
CHATGPT_URL=https://chatgpt.com/

# Queue delay between jobs
MIN_DELAY_SECONDS=60
MAX_DELAY_SECONDS=300

# Conservative UI timeouts
NAVIGATION_TIMEOUT_MS=60000
SUBMIT_ENABLE_TIMEOUT_MS=30000
GENERATION_TIMEOUT_MS=900000
COMPLETION_STABLE_MS=45000
SLOW_MO_MS=50

# Use manual_review_needed by default because this tool does not download or inspect final files.
# Allowed values: manual_review_needed, completed
JOB_DONE_STATUS=manual_review_needed

# Notifications. Leave blank to disable a provider.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NOTIFICATION_PREFIX=[chatgpt-auto-image]
